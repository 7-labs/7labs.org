# Site configuration
NEXT_PUBLIC_SITE_URL=https://7labs.org
NEXT_PUBLIC_GSC_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=

# Default: none means the project uses built-in local rule-based tools and does not call external models.
# Options: openai | google | openrouter | none
AI_PROVIDER=none

# Hard launch gate for provider-backed /api/ai calls. Keep false until auth, quotas, caching, rate limits, and spend alerts are ready.
AI_GATEWAY_ENABLED=false
AI_ALLOW_CLIENT_SYSTEM_PROMPT=false
ALLOW_CUSTOM_AI_BASE_URL=false

# OpenAI-compatible endpoint. Works for OpenAI, OpenRouter, or your own compatible gateway.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Google Gemini API (optional)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Cost-control recommendation: production should add login, quotas, IP rate limits, and caching.
FREE_DAILY_AI_LIMIT=20

# Internal event seam. Default "none" records no external analytics and returns a safe no-op response.
# Options: none | workers-analytics
ANALYTICS_PROVIDER=none
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_CF_BEACON_TOKEN=

# Newsletter capture is hidden unless a provider is configured intentionally.
# Options: none
NEWSLETTER_PROVIDER=none
NEWSLETTER_FORM_ENABLED=false
